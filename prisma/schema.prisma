generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique
  emailVerified    DateTime?
  image            String?
  role             UserRole           @default(CUSTOMER)
  hashedPassword   String?
  phone            String?
  nationality      String?
  country          String?
  state            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  dealSubscription Boolean            @default(false)
  accounts         Account[]
  bookings         Booking[]
  conversations    ChatConversation[] @relation("CustomerConversations")
  messages         ChatMessage[]
  reviews          Review[]
  sessions         Session[]
  wishlists        Wishlist[]
}

model Tour {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  shortDescription String             @db.Text
  description      String             @db.LongText
  highlights       String             @db.LongText
  includes         String             @db.LongText
  excludes         String             @db.LongText
  importantInfo    String             @db.LongText
  itinerary        String             @db.LongText
  duration         Float
  durationType     String             @default("days")
  maxGroupSize     Int
  minGroupSize     Int                @default(1)
  dailyCapacity    Int                @default(10)
  meetingPoint     String
  endPoint         String?
  location         String
  prefecture       String?
  country          String             @default("Japan")
  countryCode      String?
  stateCode        String?
  category         TourCategory
  difficulty       TourDifficulty     @default(MODERATE)
  languages        String             @db.LongText
  serviceProvider  String?
  basePrice        Decimal            @db.Decimal(10, 2)
  childPrice       Decimal?           @db.Decimal(10, 2)
  priceTiers       String?            @db.LongText
  variations       String?            @db.LongText
  startTimes       String?            @db.LongText
  status           TourStatus         @default(DRAFT)
  featured         Boolean            @default(false)
  likelyToSellOut  Boolean            @default(false)
  rating           Decimal?           @db.Decimal(3, 2)
  reviewCount      Int                @default(0)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  baseGroupSize    Int                @default(4)
  tourType         TourType           @default(GROUP)
  bookings         Booking[]
  discounts        DiscountCode[]
  reviews          Review[]
  availability     TourAvailability[]
  images           TourImage[]
  wishlists        Wishlist[]

  @@index([status, featured])
  @@index([slug])
  @@index([category])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  tourId    String
  createdAt DateTime @default(now())
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@index([userId])
  @@index([tourId])
}

model TourImage {
  id        String  @id @default(cuid())
  tourId    String
  url       String
  altText   String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
  tour      Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model Review {
  id        String   @id @default(cuid())
  tourId    String
  userId    String
  rating    Int
  message   String   @db.Text
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tourId, userId])
  @@index([tourId])
  @@index([userId])
}

model TourAvailability {
  id            String             @id @default(cuid())
  tourId        String
  date          DateTime           @db.Date
  startTime     String?
  maxCapacity   Int
  bookedCount   Int                @default(0)
  priceOverride Decimal?           @db.Decimal(10, 2)
  status        AvailabilityStatus @default(AVAILABLE)
  bookings      Booking[]
  tour          Tour               @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, date])
  @@index([tourId, status])
}

model Booking {
  id               String             @id @default(cuid())
  bookingRef       String             @unique
  tourId           String
  availabilityId   String?
  customerId       String?
  guestName        String?
  guestEmail       String
  guestPhone       String?
  tourDate         DateTime           @db.Date
  numAdults        Int
  numChildren      Int                @default(0)
  specialRequests  String?            @db.Text
  subtotal         Decimal            @db.Decimal(10, 2)
  discountAmount   Decimal            @default(0.00) @db.Decimal(10, 2)
  totalAmount      Decimal            @db.Decimal(10, 2)
  currency         String             @default("USD")
  paymentMethod    PaymentMethod
  paymentStatus    PaymentStatus      @default(PENDING)
  stripeSessionId  String?
  stripePaymentId  String?
  bankTransferRef  String?
  paidAt           DateTime?
  status           BookingStatus      @default(PENDING)
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  cancellationNote String?            @db.Text
  isManualEntry    Boolean            @default(false)
  adminNotes       String?            @db.Text
  discountCodeId   String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  availability     TourAvailability?  @relation(fields: [availabilityId], references: [id])
  customer         User?              @relation(fields: [customerId], references: [id])
  discountCode     DiscountCode?      @relation(fields: [discountCodeId], references: [id])
  tour             Tour               @relation(fields: [tourId], references: [id])
  passengers       BookingPassenger[]
  conversation     ChatConversation?

  @@index([tourId])
  @@index([customerId])
  @@index([status, paymentStatus])
  @@index([tourDate])
  @@index([guestEmail])
  @@index([availabilityId], map: "Booking_availabilityId_fkey")
  @@index([discountCodeId], map: "Booking_discountCodeId_fkey")
}

model BookingPassenger {
  id          String    @id @default(cuid())
  bookingId   String
  firstName   String
  lastName    String
  nationality String?
  passportNo  String?
  dateOfBirth DateTime? @db.Date
  isLead      Boolean   @default(false)
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model DiscountCode {
  id               String       @id @default(cuid())
  code             String       @unique
  description      String?
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  minBookingAmount Decimal?     @db.Decimal(10, 2)
  maxUses          Int?
  currentUses      Int          @default(0)
  validFrom        DateTime
  validUntil       DateTime?
  isActive         Boolean      @default(true)
  tourId           String?
  createdAt        DateTime     @default(now())
  bookings         Booking[]
  tour             Tour?        @relation(fields: [tourId], references: [id])

  @@index([code, isActive])
  @@index([tourId], map: "DiscountCode_tourId_fkey")
}

model Destination {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  places    Place[]
}

model Place {
  id            String      @id @default(cuid())
  destinationId String
  name          String
  subtitle      String?
  imageUrl      String?
  linkQuery     String?
  order         Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
}

model ChatConversation {
  id            String             @id @default(cuid())
  type          ConversationType
  bookingId     String?            @unique
  customerId    String?
  visitorId     String?
  visitorName   String?
  visitorEmail  String?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  booking       Booking?           @relation(fields: [bookingId], references: [id])
  customer      User?              @relation("CustomerConversations", fields: [customerId], references: [id])
  messages      ChatMessage[]

  @@index([type, status])
  @@index([customerId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String?
  senderName     String
  senderRole     SenderRole
  content        String           @db.Text
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?            @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model EmailLog {
  id        String      @id @default(cuid())
  to        String
  subject   String
  type      EmailType
  bookingId String?
  status    EmailStatus @default(QUEUED)
  sentAt    DateTime?
  error     String?     @db.Text
  createdAt DateTime    @default(now())

  @@index([bookingId])
  @@index([status])
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum TourCategory {
  CULTURAL
  ADVENTURE
  FOOD_AND_DRINK
  NATURE
  CITY_TOUR
  DAY_TRIP
  MULTI_DAY
  PRIVATE
  GROUP
}

enum TourDifficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum TourStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TourType {
  SOLO
  GROUP
}

enum AvailabilityStatus {
  AVAILABLE
  FULL
  CLOSED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  PAID
  REFUNDED
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ConversationType {
  BOOKING_SUPPORT
  VISITOR_CS
}

enum ConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

enum SenderRole {
  ADMIN
  CUSTOMER
  VISITOR
}

enum EmailType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  MANUAL_PAYMENT_INSTRUCTIONS
  ADMIN_NEW_BOOKING
  ADMIN_NEW_MESSAGE
  EMAIL_VERIFICATION
  WISHLIST_DISCOUNT
  GUIDE_MESSAGE
  DEAL_ALERT
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}
